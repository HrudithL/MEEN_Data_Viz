# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Postgres URI for npm run db:migrate (Project Settings → Database)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# App URL (used for invite links and server-side fetches)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: email invites (Org Settings → Invite member)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Optional: local demo admin quick sign-in (login page button)
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=admin@demo.meendataviz.local
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=DemoAdmin123!
